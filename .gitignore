profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version if you
#   use pyenv and want to lock a version for other developers.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing pipelines, you may want to ignore it.
# Pipfile.lock

# poetry
#   poetry.lock is recommended to be checked in if it's an app, but not if it's a library.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, poetry.lock, pdm.lock is checked in by default.
# pdm.lock
.pdm-plugins/
.pdm-build/

# PEP 582; used by e.g. github.com/davidhalter/jedi
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

