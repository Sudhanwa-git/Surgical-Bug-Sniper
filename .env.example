# ── Surgical Bug Sniper — Environment Configuration ──────────────────────────

# GitHub Personal Access Token (required for fork + PR creation)
GITHUB_TOKEN=your_github_personal_access_token_here

# Ollama model identifier (must match `ollama list` output)
OLLAMA_MODEL=qwen2.5-coder:7b

# Ollama API base URL
OLLAMA_API_BASE=http://localhost:11434

# ── Tuning ───────────────────────────────────────────────────────────────────

# Max source characters sent to LLM as context (higher = better quality, slower)
SURGERY_CONTEXT_CHARS=35000

# Ollama API timeout in seconds
SURGERY_TIMEOUT_SEC=180

# Max bugs to attempt per repo per run
MAX_BUGS_PER_REPO=3
