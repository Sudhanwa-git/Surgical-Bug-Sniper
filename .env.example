# .env.example - Environment Template for Surgical Bug Sniper (SBK)

# Aider Model Specification (use the ollama_chat/ prefix to talk to Ollama via Aider)
AIDER_MODEL=ollama_chat/qwen2.5-coder:7b

# Default Ollama API base URL
OLLAMA_API_BASE=http://localhost:11434

# GitHub API Token (Required for fork & pull request creation tasks)
GITHUB_TOKEN=your_github_personal_access_token_here

# ── Speed / Quality Tuning ───────────────────────────────────────────────────
# Max source characters sent to the LLM as context (higher = better quality, slower)
SURGERY_CONTEXT_CHARS=35000

# Ollama API response timeout in seconds
SURGERY_TIMEOUT_SEC=180

# Maximum number of bugs to attempt per repository in a single execution run
MAX_BUGS_PER_REPO=3
